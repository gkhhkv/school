<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Lombok @Data generates getter/setter for List fields; DTO/entity patterns require mutable lists -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="com.example.ecommerce.domain.Order"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="com.example.ecommerce.dto.OrderCreateRequest"/>
    </Match>
</FindBugsFilter>
